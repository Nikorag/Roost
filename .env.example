# Postgres (Neon, Supabase, local, etc.)
DATABASE_URL=postgres://user:pass@host:5432/roost

# Auth.js (NextAuth) — generate a secret: `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OIDC provider (any OIDC-compliant: Authentik, Keycloak, Auth0, Google, etc.)
OIDC_ISSUER=https://your-issuer.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional override of provider name shown on login button
OIDC_PROVIDER_NAME=SSO

# Google Cloud Storage
GCS_BUCKET=roost-uploads
# Service-account JSON pasted in as a single env value.
# Either the raw JSON (newlines in private_key are fine if your host preserves them)
# or a base64-encoded version of the same JSON — both are accepted.
GCS_CREDENTIALS_JSON=

# Google Generative AI (Gemini) for the new-project wizard
GOOGLE_GENERATIVE_AI_API_KEY=

# Allowed login emails (comma-separated). Empty = allow anyone who can authenticate.
ALLOWED_EMAILS=

# Public base URL used in ICS feed links
APP_URL=http://localhost:3000
